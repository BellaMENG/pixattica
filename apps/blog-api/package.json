{
    "name": "@pixattica/blog-api",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wrangler dev --config wrangler.jsonc --port 4176 --persist-to .wrangler/state",
        "build": "wrangler deploy --config wrangler.jsonc --dry-run --outdir dist && tsc -p tsconfig.json --noEmit",
        "test": "vitest run --config vitest.config.mts",
        "deploy": "wrangler deploy --config wrangler.jsonc",
        "db:migrate:local": "wrangler d1 migrations apply DB --config wrangler.jsonc --local --persist-to .wrangler/state",
        "db:migrate:remote": "wrangler d1 migrations apply DB --config wrangler.jsonc --remote",
        "types": "wrangler types src/worker-configuration.d.ts --config wrangler.jsonc --env-interface CloudflareBindings",
        "clean": "rm -rf dist node_modules .turbo"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.1",
        "hono": "^4.12.9"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260317.1",
        "@types/node": "^25.5.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0",
        "wrangler": "^4.76.0"
    }
}
