{
    "name": "pixattica",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "build:blog-admin": "turbo build --filter=@pixattica/blog-admin",
        "build:blog-api": "turbo build --filter=@pixattica/blog-api",
        "build:landing": "turbo build --filter=@pixattica/landing",
        "dev": "turbo dev --parallel --ui=tui --filter=@pixattica/landing",
        "dev:blog": "turbo dev --parallel --ui=tui --filter=@pixattica/landing --filter=@pixattica/blog-api --filter=@pixattica/blog-admin",
        "dev:all": "turbo dev --parallel --ui=tui",
        "setup:env": "bash ./scripts/setup-env.sh",
        "lint": "oxlint .",
        "format": "oxfmt --list-different .",
        "format:check": "oxfmt --check .",
        "test": "turbo test",
        "test:blog-admin": "turbo test --filter=@pixattica/blog-admin",
        "test:blog-api": "turbo test --filter=@pixattica/blog-api",
        "test:landing": "turbo test --filter=@pixattica/landing",
        "clean": "turbo clean",
        "prepare": "husky"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "oxfmt": "^0.28.0",
        "oxlint": "^1.43.0",
        "turbo": "^2"
    },
    "lint-staged": {
        "**/*.{js,jsx,ts,tsx}": [
            "oxlint",
            "oxfmt"
        ],
        "**/*.{json,md,css,html,yml,yaml}": [
            "oxfmt"
        ]
    },
    "packageManager": "pnpm@10.32.1"
}
