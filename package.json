{
    "name": "pixattica",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev --parallel",
        "lint": "oxlint .",
        "format": "oxfmt --list-different .",
        "format:check": "oxfmt --check .",
        "test": "turbo test",
        "clean": "turbo clean",
        "prepare": "husky"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "oxfmt": "^0.28.0",
        "oxlint": "^1.43.0",
        "turbo": "^2"
    },
    "lint-staged": {
        "**/*.{js,jsx,ts,tsx}": [
            "oxlint",
            "oxfmt"
        ],
        "**/*.{json,md,css,html,yml,yaml}": [
            "oxfmt"
        ]
    },
    "packageManager": "pnpm@10.32.1"
}
